# Required for production (and recommended for local use)
# ADMIN_PASSWORD bootstraps data/admin.json on first run only.
# Change the password later from the dashboard Settings tab.
ADMIN_PASSWORD=change-me
SESSION_SECRET=replace-with-a-long-random-string

# Server
# Use HOST=0.0.0.0 only behind a reverse proxy or in Docker.
PORT=3847
HOST=127.0.0.1

# Public URL of this TinyFeedback instance (used in install snippets).
# Also editable in dashboard Settings.
PUBLIC_URL=https://tinyfeedback.example.com

# Spam protection for public POST /api/feedback (per client IP)
FEEDBACK_RATE_MAX=30
FEEDBACK_RATE_WINDOW_MS=900000
